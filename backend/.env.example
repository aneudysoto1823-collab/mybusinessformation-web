# ============================================================================
# OpaBiz — Variables de entorno (plantilla)
# ----------------------------------------------------------------------------
# Copia este archivo a `.env.local` (Next.js) y completa los valores reales.
# NUNCA subas el .env con valores reales al repo. En producción se configuran
# en Vercel (frontend + API) y Railway (Express).
# ============================================================================

# ── Base de datos: Supabase (REST, sin Prisma) ─────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=          # service role key — bypasa RLS, solo server-side

# ── Autenticación ──────────────────────────────────────────────────────────
SESSION_SECRET=                     # JWT admin (HS256). Usa 32+ chars aleatorios
ADMIN_USER=                         # usuario del login admin
ADMIN_PASSWORD_HASH=                # hash de la contraseña admin (no texto plano)
ADMIN_EMAIL=                        # correo para recuperación de contraseña admin
ENCRYPTION_KEY=                     # clave de cifrado de datos sensibles

# ── Pagos: Stripe ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=                  # sk_test_... (dev) | sk_live_... (prod)
STRIPE_WEBHOOK_SECRET=              # whsec_... del endpoint de webhook

# ── Email: Resend ──────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_TRANSACTIONAL=          # ej: OpaBiz <noreply@opabiz.com>
RESEND_FROM_MARKETING=              # ej: OpaBiz <marketing@opabiz.com>
RESEND_FROM_SUPPORT=                # ej: OpaBiz <support@opabiz.com>
RESEND_REPLY_TO=                    # ej: support@opabiz.com
INTERNAL_ALERT_EMAIL=               # ej: alert@opabiz.com (alertas internas: nueva orden)
CONTACT_FROM_EMAIL=                 # remitente del formulario de contacto
CONTACT_TO_EMAIL=                   # destino del formulario de contacto

# ── Next.js ↔ Express (Railway) ────────────────────────────────────────────
INTERNAL_API_KEY=                   # compartido entre Vercel y Railway (header x-api-key)
BACKEND_URL=                        # URL del Express en Railway
PORT=4000                           # puerto del Express (default 4000)

# ── URLs públicas ──────────────────────────────────────────────────────────
NEXT_PUBLIC_URL=https://opabiz.com  # base del sitio (links de emails de citas, etc.)
NEXT_PUBLIC_BASE_URL=https://opabiz.com

# ── Analytics ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=                  # Google Analytics 4 (G-XXXXXXXXXX)

# ── IA: Anthropic (análisis de facturas en contabilidad) ───────────────────
ANTHROPIC_API_KEY=                  # claude-haiku-4-5 para extraer datos de facturas

# ── Rate limiting / cache: Upstash Redis ───────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Auto-configuradas por la plataforma (NO setear manualmente) ────────────
# NODE_ENV       — Next.js / Node lo setea (development | production)
# VERCEL_ENV     — Vercel lo setea (production | preview | development)
