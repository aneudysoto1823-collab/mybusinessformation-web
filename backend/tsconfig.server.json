{
  "compilerOptions": {
    "target": "ES2017",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "rootDir": ".",
    "outDir": "./dist-server",
    "sourceMap": true
  },
  "include": [
    "server.ts",
    "modules/**/*.ts"
  ],
  "exclude": ["node_modules", "dist-server"]
}
