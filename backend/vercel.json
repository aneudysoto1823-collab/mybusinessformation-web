{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "app/api/cron/sunbiz-daily/route.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/sunbiz-daily",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/priority-filing-notice",
      "schedule": "*/30 * * * *"
    }
  ]
}
