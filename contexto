## Cómo funciona el sistema (Etapa 1)
Cada page.tsx lee su HTML original y lo renderiza en Next.js.
El page.tsx correcto extrae TANTO el style como el body del HTML:

import fs from 'fs'
import path from 'path'
export default function About() {
  const htmlPath = path.join(process.cwd(), '..', 'about.html')
  const rawHtml = fs.readFileSync(htmlPath, 'utf-8')
  const styleMatch = rawHtml.match(/<style[^>]*>([\s\S]*?)<\/style>/i)
  const styleContent = styleMatch ? styleContent = styleMatch ? `<style>${styleMatch[1]}</style>` : ''
  const bodyMatch = rawHtml.match(/<body[^>]*>([\s\S]*)<\/body>/i)
  const bodyContent = bodyMatch ? bodyMatch[1] : ''
  return (
    <main dangerouslySetInnerHTML={{ __html: styleContent + bodyContent }} />
  )
}

